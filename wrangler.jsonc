{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "weymann-gebaeudetechnik",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "main": "worker.js",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "website-datein"
    }
  ]
}
